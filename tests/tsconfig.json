{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "target": "es2019",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": true,
    "strictNullChecks": true,
    "allowJs": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "src/**/*",
    "*.ts",
    "utils/**/*",
    "pages/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
